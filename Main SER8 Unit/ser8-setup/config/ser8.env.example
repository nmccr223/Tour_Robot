# SER8_ENVIRONMENT_VARIABLES

# Example environment configuration for the SER8 system

# Set the CM5 host IP address
CM5_HOST=192.168.10.20

# Set the CM5 user for SSH access
CM5_USER=tourrobot

# Set the services to monitor
SERVICES=ld19.service,ld19-stack.service

# Set the path to the ROS 2 workspace
ROS2_WS_PATH=/home/your_username/ros2_ws

# Set the ROS 2 distribution
ROS2_DISTRO=jazzy

# Set the watchdog check interval in seconds
WATCHDOG_INTERVAL=60

# Set the log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO